---
/**
 * Hero — vídeo del iPhone con fondo transparente (HEVC alfa + fallbacks).
 * Al terminar la animación: el iPhone se desliza a la derecha y aparece
 * el bloque de copy (cara, pill, titular, subtítulo, CTA) a la izquierda.
 */
import VelvzFace from './VelvzFace.astro';
---

<section class="hero" id="top">
  <!-- Sources del vídeo y src del hero-final.png se inyectan por JS
       basándose en el viewport (desktop vs móvil). Lo dejamos vacío en
       HTML para que el browser no empiece a cargar el vídeo desktop
       antes de que el script tenga tiempo de elegir el correcto. -->
  <video
    class="hero__video"
    autoplay
    muted
    playsinline
  ></video>

  <img class="hero__final" alt="" aria-hidden="true" />

  <div class="hero__copy">
    <div class="hero__face">
      <VelvzFace size={120} color="#FFFFFF" />
    </div>

    <h1 class="hero__title">
      <span class="hero__title-line"><em>Velvz</em>,</span>
      <span class="hero__title-line">entiende tu dinero.</span>
    </h1>

    <p class="hero__subtitle">
      Visualiza tu dinero en lenguaje natural.
    </p>

    <div class="hero__cta-wrap">
      <a href="#waitlist" class="hero__cta">
        <span class="hero__cta-bg" aria-hidden="true"></span>
        <span class="hero__cta-text">Solicitar acceso a la beta</span>
        <svg class="hero__cta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M13 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>

<script is:inline>
  /* Inyección de sources según viewport. Se ejecuta ANTES del módulo
     de slide/reveal para que el browser empiece a precargar el vídeo
     correcto sin descargar primero el desktop si estamos en móvil. */
  (() => {
    const video = document.querySelector('.hero__video');
    const heroFinal = document.querySelector('.hero__final');
    if (!video) return;

    const isMobile = window.matchMedia('(max-width: 820px)').matches;
    const sources = isMobile ? [
      ['/videos/hero-mobile.mov', 'video/mp4; codecs=hvc1'],
      ['/videos/hero-mobile.webm', 'video/webm'],
      ['/videos/hero-mobile.mp4', 'video/mp4'],
    ] : [
      ['/videos/hero.mov', 'video/mp4; codecs=hvc1'],
      ['/videos/hero.webm', 'video/webm'],
      ['/videos/hero.mp4', 'video/mp4'],
    ];

    sources.forEach(([src, type]) => {
      const source = document.createElement('source');
      source.src = src;
      source.type = type;
      video.appendChild(source);
    });

    video.poster = isMobile
      ? '/videos/hero-mobile-poster-start.jpg'
      : '/videos/hero-poster-start.jpg';
    video.preload = 'auto';
    video.load();

    if (heroFinal) {
      heroFinal.src = isMobile
        ? '/videos/hero-mobile-final.png'
        : '/videos/hero-final.png';
    }
  })();

  (() => {
    const hero = document.querySelector('.hero#top');
    const video = hero?.querySelector('video.hero__video');
    if (!hero || !video) return;
    const isMobile = window.matchMedia('(max-width: 820px)').matches;
    const SLIDE_AT = 5;
    // REVEAL_LEAD viewport-aware: en desktop hay slide horizontal de 1.8s
    // y queremos margen para que el PNG limpio tape el último frame
    // (1s lead). En móvil el iPhone se mueve hasta el final del vídeo
    // (la animación TIENE incluido el desplazamiento), así que hay que
    // esperar hasta casi el final — 0.1s, no más.
    const REVEAL_LEAD = isMobile ? 0.1 : 1.0;
    let slid = false, revealed = false;
    const slide = () => { if (slid) return; slid = true; hero.classList.add('is-sliding'); };
    // Reveal: el PNG está SIEMPRE pintado detrás del vídeo. Solo hay
    // que ocultar el vídeo (display:none) y el PNG queda visible al
    // instante — sin opacity transition, sin paint gap, sin frame
    // negro. Se dispara 1 s antes del fin del vídeo para tener margen.
    const reveal = () => {
      slide();
      if (revealed) return;
      revealed = true;
      hero.classList.add('is-revealed');
      video.style.display = 'none';
    };
    if (video.ended) reveal();
    else if (video.currentTime >= SLIDE_AT) slide();
    // timeupdate maneja AMBOS triggers:
    //   - slide a SLIDE_AT s
    //   - reveal a duration - REVEAL_LEAD s
    const onTime = () => {
      if (!slid && video.currentTime >= SLIDE_AT) slide();
      if (!revealed && video.duration && video.currentTime >= video.duration - REVEAL_LEAD) {
        reveal();
      }
      if (slid && revealed) {
        video.removeEventListener('timeupdate', onTime);
      }
    };
    video.addEventListener('timeupdate', onTime);
    // Fallback por si timeupdate no disparase a tiempo.
    video.addEventListener('ended', reveal, { once: true });

    // Fallback adicional para móvil: si autoplay está bloqueado o el
    // vídeo no avanza por algún motivo, en 8s forzamos el slide para
    // que la copy aparezca igualmente. `slide()` es idempotente.
    setTimeout(slide, 8000);
  })();
</script>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    background: #000;
    overflow: hidden;
  }

  /* ── Vídeo y PNG final ─────────────────────────────────────────
     Truco para que NO haya frame negro al hacer el swap:
       1. PNG limpio SIEMPRE detrás del vídeo (z-index 1, opacity 1).
          Está cargado y pintado desde el inicio, solo está tapado por
          el vídeo opaco que tiene encima.
       2. Vídeo con `background: #000` propio (z-index 2). Como el
          HEVC alfa tiene transparencia alrededor del iPhone, esa zona
          transparente del frame muestra el bg negro del propio
          elemento de vídeo — NO el PNG de detrás. Así el PNG no se ve
          durante la animación.
       3. Al revelar: `video.style.display = 'none'`. El PNG (que ya
          estaba pintado) queda inmediatamente visible. Sin opacity
          transition, sin paint gap → imposible un frame en negro. */
  .hero__video,
  .hero__final {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    pointer-events: none;
    transition: transform 1.8s cubic-bezier(0.55, 0, 0.65, 0.92);
  }
  .hero__final {
    z-index: 1; /* DETRÁS, siempre visible (tapado por el vídeo) */
  }
  .hero__video {
    z-index: 2;
    background: #000; /* tapa al PNG por las zonas transparentes del HEVC */
  }

  /* ── Copy a la izquierda ──────────────────────────────────── */
  .hero__copy {
    position: absolute;
    top: 50%;
    left: 7%;
    width: 44%;
    max-width: 520px;
    transform: translateY(-50%);
    z-index: 3;
    opacity: 0;
    pointer-events: none;
    transition: opacity 1.4s ease-out 1s;
  }
  .hero.is-sliding .hero__copy {
    opacity: 1;
    pointer-events: auto;
  }

  /* iPhone slides right cuando empieza el reveal (desktop only). Aplica
     a vídeo y PNG en paralelo para que ambos estén en la misma posición
     en el momento del crossfade y no haya salto. */
  @media (min-width: 821px) {
    .hero.is-sliding .hero__video,
    .hero.is-sliding .hero__final {
      transform: translateX(22%);
    }
  }

  /* ── Cara ─────────────────────────────────────────────────── */
  .hero__face {
    margin-bottom: 28px;
  }

  /* ── Pill ─────────────────────────────────────────────────── */
  .hero__pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 14px 7px 12px;
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--text);
    margin-bottom: 24px;
  }
  .hero__pill-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 12px var(--accent-glow);
    animation: pillPulse 2.4s ease-in-out infinite;
  }
  @keyframes pillPulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.5; transform: scale(0.85); }
  }

  /* ── Título ───────────────────────────────────────────────── */
  .hero__title {
    margin: 0 0 22px;
    font-size: clamp(40px, 5.2vw, 76px);
    font-weight: 700;
    line-height: 0.98;
    letter-spacing: -0.035em;
    color: var(--text);
  }
  .hero__title-line { display: block; }
  .hero__title em {
    font-style: normal;
    /* Mismos azules del glow de "IA pensando" en la app real
       (ContentView.swift:280-286): claro → medio → oscuro. */
    background: linear-gradient(120deg, #4D99E6 0%, #1A66FF 50%, #003399 100%);
    background-size: 200% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: gradientSlide 8s ease-in-out infinite;
  }
  @keyframes gradientSlide {
    0%, 100% { background-position: 0% 50%; }
    50%      { background-position: 100% 50%; }
  }

  /* ── Subtítulo ────────────────────────────────────────────── */
  .hero__subtitle {
    margin: 0 0 32px;
    font-size: clamp(15px, 1.15vw, 18px);
    line-height: 1.55;
    color: var(--text-muted);
    max-width: 480px;
  }

  /* ── CTA ──────────────────────────────────────────────────── */
  .hero__cta-wrap {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
  }
  .hero__cta {
    position: relative;
    isolation: isolate;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 16px 26px;
    border-radius: var(--radius-pill);
    color: #fff;
    font-size: 15.5px;
    font-weight: 600;
    letter-spacing: -0.005em;
    overflow: hidden;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    box-shadow:
      0 12px 40px rgba(10, 132, 255, 0.45),
      inset 0 1px 0 rgba(255, 255, 255, 0.25);
  }
  .hero__cta-bg {
    position: absolute;
    inset: 0;
    /* Mismos azules del glow IA — coherente con el titular. */
    background: linear-gradient(120deg, #4D99E6 0%, #1A66FF 50%, #003399 100%);
    background-size: 200% 100%;
    z-index: -1;
    animation: gradientSlide 6s ease-in-out infinite;
  }
  .hero__cta-icon { width: 18px; height: 18px; transition: transform 0.25s ease; }
  .hero__cta:hover {
    transform: translateY(-2px);
    box-shadow:
      0 20px 60px rgba(10, 132, 255, 0.6),
      inset 0 1px 0 rgba(255, 255, 255, 0.3);
  }
  .hero__cta:hover .hero__cta-icon { transform: translateX(4px); }
  .hero__cta-hint { margin: 0; font-size: 12.5px; color: var(--text-subtle); }

  /* ── Mobile portrait: vídeo nativo vertical ──────────────────────
     El vídeo de móvil (1170×2532, 9:19.5) tiene el desplazamiento del
     iPhone hacia arriba metido en la propia animación. Solo necesitamos:
       - mostrar el vídeo a tamaño completo (100vh, contain — coincide
         exactamente en aspect ratio con la mayoría de móviles modernos)
       - posicionar la copy absolute en la parte INFERIOR del viewport
         para que caiga sobre la zona transparente que la animación
         libera al subir el iPhone
       - revelar la copy con `is-revealed` (no con `is-sliding`) — el
         is-revealed dispara cuando el vídeo está casi al final, momento
         en el que el iPhone ya está en su pose final arriba. */
  @media (max-width: 820px) {
    .hero {
      height: 100vh;
      min-height: auto;
      padding: 0;
    }

    /* En móvil dejamos el iPhone un pelín más pequeño que el contain
       natural (88 %) y con origen ligeramente bajo (center 60 %) → la
       reducción crea aire arriba para que no toque el header sin
       reposicionar el elemento (lo que provocaba saltos al pintar). */
    .hero__video,
    .hero__final {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: contain;
      object-position: center;
      transform: scale(0.88);
      transform-origin: center 60%;
      transition: none;
      will-change: auto;
    }

    /* Override del slide desktop — en móvil no hay slide visual, mantenemos
       la escala 0.88 también durante is-sliding. */
    .hero.is-sliding .hero__video,
    .hero.is-sliding .hero__final {
      transform: scale(0.88);
      transform-origin: center 60%;
      height: 100%;
    }

    /* Copy absolute en la parte baja del viewport, sobre la zona
       transparente que el vídeo libera al subir el iPhone. */
    .hero__copy {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      top: auto;
      width: 100%;
      max-width: 540px;
      margin: 0 auto;
      padding: 0 24px 56px;
      transform: none;
      text-align: center;
      z-index: 4;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.8s ease-out 0.15s;
    }

    /* En móvil la copy NO se revela con is-sliding (override de la
       regla desktop que ponía opacity:1) — usa is-revealed en su lugar,
       que dispara cuando el iPhone ya está en su pose final arriba. */
    .hero.is-sliding .hero__copy {
      opacity: 0;
      pointer-events: none;
    }
    .hero.is-revealed .hero__copy {
      opacity: 1;
      pointer-events: auto;
    }

    /* Cara oculta en móvil — la marca ya viene reforzada por el iPhone
       en pantalla y por la marca "Velvz" del propio título. Liberamos
       ~120px verticales para que el copy respire. */
    .hero__face { display: none; }
    .hero__title {
      font-size: clamp(28px, 7.5vw, 42px);
      line-height: 1.05;
      margin-bottom: 14px;
    }
    .hero__subtitle {
      margin: 0 auto 22px;
      font-size: 14.5px;
      max-width: 460px;
    }
    .hero__cta-wrap { align-items: center; }
    .hero__cta {
      padding: 12px 20px;
      font-size: 14px;
    }
  }

  /* Pantalla pequeña (iPhone SE, etc.) */
  @media (max-width: 480px) {
    .hero__title { font-size: clamp(26px, 8vw, 36px); }
    .hero__face { margin-bottom: 12px; }
    .hero__subtitle { font-size: 14px; }
  }
</style>
