---
/**
 * Sección 3 — Categorización automática
 *
 * Split asimétrico:
 *   ←  Copy a la izquierda (40%)
 *   →  Ventana mockup con lista de movimientos categorizándose en directo (60%)
 *
 * Cuando arranca la categorización, la ventana entra en modo "is-thinking":
 * un glow azul/cyan rota alrededor del borde — clavado a la animación de IA
 * de la app real (ContentView.swift:272-298, AngularGradient + blur, 5 s/giro).
 *
 * Al terminar de categorizar, el glow fade-out, pausa, y vuelve a empezar.
 *
 * Cada fila muestra:
 *   - Icono cuadrado coloreado con símbolo blanco
 *   - Merchant + descriptor en MAYÚS pequeñas + tag(s) inline
 *   - Fecha (gris) + importe (rojo gastos / verde ingresos)
 */

type Movement = {
  merchant: string;
  descriptor: string;       // texto secundario en MAYÚS pequeñas
  tags: string[];           // pills al lado del descriptor
  date: string;
  amount: string;
  income?: boolean;
  category: string;
  color: string;
  icon: string;
};

const movements: Movement[] = [
  { merchant: 'Mercadona', descriptor: 'MERCADONA SC SOL', tags: ['Necesario'],
    date: '28 abr 2026', amount: '-34,20 €',
    category: 'supermercado', color: '#34D158', icon: 'bag' },
  { merchant: 'Amazon', descriptor: 'AMAZON EU SARL — COMPRA', tags: ['Revisar'],
    date: '27 abr 2026', amount: '-67,50 €',
    category: 'compras', color: '#5AC8FA', icon: 'monitor' },
  { merchant: 'Restaurante La Bola', descriptor: 'RESTAURANTE LA BOLA', tags: ['Ocio'],
    date: '25 abr 2026', amount: '-29,40 €',
    category: 'restaurantes', color: '#FF9F0A', icon: 'fork' },
  { merchant: 'Bizum Padre', descriptor: 'BIZUM ENVIADO PADRE — REGALO', tags: ['Bizum'],
    date: '24 abr 2026', amount: '-45,00 €',
    category: 'transferencias', color: '#FFD60A', icon: 'gift' },
  { merchant: 'Farmacia Calle Mayor', descriptor: 'FARMACIA CALLE MAYOR', tags: ['Necesario'],
    date: '23 abr 2026', amount: '-11,50 €',
    category: 'salud', color: '#FF6961', icon: 'heart' },
  { merchant: 'CEPSA Gasolinera', descriptor: 'CEPSA E.S. CHAMARTÍN', tags: ['Necesario'],
    date: '22 abr 2026', amount: '-51,20 €',
    category: 'transporte', color: '#0A84FF', icon: 'car' },
  { merchant: 'Spotify', descriptor: 'SPOTIFY PREMIUM ESP', tags: ['Recurrente'],
    date: '20 abr 2026', amount: '-11,99 €',
    category: 'suscripciones', color: '#FF6FAA', icon: 'music' },
  { merchant: 'Nómina Acme S.L.', descriptor: 'NOMINA ACME SL', tags: ['Trabajo'],
    date: '01 abr 2026', amount: '+2 180,00 €', income: true,
    category: 'ingresos', color: '#34D158', icon: 'arrow-up' },
];

// Total = suma de los importes mostrados
// -34.20 -67.50 -29.40 -45.00 -11.50 -51.20 -11.99 +2180.00 = +1929.21
const monthTotal = '+1 929,21 €';
---

<section class="mvtos" id="movimientos">
  <div class="mvtos__bg" aria-hidden="true">
    <div class="mvtos__halo"></div>
  </div>

  <div class="container container--wide mvtos__inner">
    <!-- ── Izquierda: copy ───────────────────────────────── -->
    <div class="mvtos__col mvtos__col--text">
      <h2 class="section-title reveal">
        <em>Organizamos</em><br /> tus movimientos.
      </h2>
      <p class="section-lead reveal" style="--reveal-delay: .1s">
        Velvz lee tus extractos, entiende el contexto y asigna cada gasto
        a su categoría. Y aprende cada vez que la corriges.
      </p>
    </div>

    <!-- ── Derecha: ventana con lista ────────────────────── -->
    <div class="mvtos__col mvtos__col--shot reveal" style="--reveal-delay: .2s">
      <div class="mvwin-wrap" data-mvwin-wrap>
        <!-- Glow IA: rect MÁS PEQUEÑO que .mvwin → bg opaco tapa las aristas,
             solo escapa el blur como halo difuso (sin recortes/máscaras) -->
        <div class="mvwin__aiglow" aria-hidden="true"></div>

        <div class="mvwin">
        <header class="mvwin__head">
          <h3>Movimientos</h3>
          <span class="mvwin__pill">Todo</span>
        </header>

        <div class="mvwin__month">
          <span class="mvwin__month-name">Abril 2026</span>
          <span class="mvwin__month-total">{monthTotal}</span>
        </div>

        <ul class="mvlist">
          {movements.map((m) => (
            <li
              class="mvr"
              style={`--mvr-color: ${m.color}`}
              data-row
            >
              <span class="mvr__icon">
                <span class="mvr__icon-spinner" aria-hidden="true"></span>
                <svg class="mvr__icon-svg" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  {m.icon === 'bag' && (
                    <Fragment>
                      <path d="M5 8h14l-1 12H6z" />
                      <path d="M8 8V6a4 4 0 0 1 8 0v2" />
                    </Fragment>
                  )}
                  {m.icon === 'monitor' && (
                    <Fragment>
                      <rect x="3" y="4" width="18" height="13" rx="2" />
                      <path d="M8 21h8M12 17v4" />
                    </Fragment>
                  )}
                  {m.icon === 'fork' && (
                    <Fragment>
                      <path d="M8 3v8a2 2 0 1 0 4 0V3" />
                      <path d="M10 11v10" />
                      <path d="M16 3l-1 6 2 1v11" />
                    </Fragment>
                  )}
                  {m.icon === 'gift' && (
                    <Fragment>
                      <rect x="3" y="9" width="18" height="12" rx="1" />
                      <path d="M3 13h18M12 9v12" />
                      <path d="M8 9a3 3 0 1 1 4-3 3 3 0 1 1 4 3" />
                    </Fragment>
                  )}
                  {m.icon === 'heart' && (
                    <path d="M12 20s-7-4.4-7-10a4 4 0 0 1 7-2.6A4 4 0 0 1 19 10c0 5.6-7 10-7 10z" />
                  )}
                  {m.icon === 'car' && (
                    <Fragment>
                      <path d="M5 17h14l-2-7H7z" />
                      <circle cx="8" cy="18" r="1.6" />
                      <circle cx="16" cy="18" r="1.6" />
                    </Fragment>
                  )}
                  {m.icon === 'music' && (
                    <Fragment>
                      <path d="M9 18a3 3 0 1 1-2-2.83V6l11-2v12.17A3 3 0 1 1 16 12V6L9 7.5z" />
                    </Fragment>
                  )}
                  {m.icon === 'arrow-up' && (
                    <Fragment>
                      <path d="M12 19V5" />
                      <path d="M5 12l7-7 7 7" />
                    </Fragment>
                  )}
                </svg>
              </span>

              <div class="mvr__body">
                <p class="mvr__name">{m.merchant}</p>
                <div class="mvr__sub">
                  <span class="mvr__merch">{m.descriptor}</span>
                  {m.tags.map((t) => <span class="mvr__tag">{t}</span>)}
                </div>
              </div>

              <p class="mvr__date">{m.date}</p>
              <p class={`mvr__amount ${m.income ? 'mvr__amount--in' : ''}`}>{m.amount}</p>
            </li>
          ))}
        </ul>
        </div><!-- /.mvwin -->
      </div><!-- /.mvwin-wrap -->
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const wrap = document.querySelector('[data-mvwin-wrap]');
    if (!wrap) return;
    const rows = wrap.querySelectorAll('[data-row]');
    if (!rows.length) return;

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) {
      rows.forEach((r) => r.classList.add('is-categorized'));
      return;
    }

    const STAGGER = 700;
    const sleep = (ms) => new Promise((r) => setTimeout(r, ms));
    let started = false;

    // Una pasada y para. La rotación del glow es 100% CSS (transform sobre
    // un círculo) — corre en compositor GPU y no se throttle-a aunque la
    // página esté idle.
    const animate = async () => {
      wrap.classList.add('is-thinking');
      await sleep(500);
      for (let i = 0; i < rows.length; i++) {
        rows[i].classList.add('is-categorized');
        await sleep(STAGGER);
      }
      wrap.classList.remove('is-thinking');
    };

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting && !started) {
            started = true;
            io.disconnect();
            animate();
          }
        });
      },
      { threshold: 0.35 }
    );
    io.observe(wrap);
  })();
</script>

<style>
  .mvtos {
    position: relative;
    isolation: isolate;
    padding: var(--section-py) 0;
    overflow: hidden;
  }
  .mvtos__bg { position: absolute; inset: 0; z-index: -1; pointer-events: none; }
  .mvtos__halo {
    position: absolute;
    top: 30%;
    right: -10%;
    width: 800px;
    height: 800px;
    background: radial-gradient(circle, var(--accent) 0%, transparent 65%);
    opacity: 0.14;
    filter: blur(140px);
  }

  .mvtos__inner {
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
    gap: 80px;
    align-items: center;
  }

  /* ── Columna izquierda (copy) ─────────────────────────────── */
  .mvtos__col--text { max-width: 520px; }
  .mvtos__col--text .section-title em {
    font-style: normal;
    background: linear-gradient(120deg, #4D99E6 0%, #1A66FF 50%, #003399 100%);
    background-size: 200% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: mvGradSlide 8s ease-in-out infinite;
  }
  @keyframes mvGradSlide {
    0%, 100% { background-position: 0% 50%; }
    50%      { background-position: 100% 50%; }
  }

  /* ── Wrapper para que el glow viva como hermano (más visible) ── */
  .mvwin-wrap {
    position: relative;
  }

  /* ── Glow IA: círculo escondido + transform GPU ──────────
     CLAVE para que la animación NO se throttle-e cuando la página
     está idle (sin scroll): la rotación corre 100% en el compositor
     GPU vía `transform: rotate()`. Animaciones de conic-gradient con
     @property requieren REPAINT cada frame — y los browsers throttle-an
     repaints en idle. Las de transform son free en GPU.

     Para que la rotación sea invisible (un rectángulo rotado se ve
     girando), el elemento es un CÍRCULO inscrito dentro de .mvwin.
     Un círculo rotado se ve idéntico — solo los colores del conic-gradient
     fluyen. Como el círculo está escondido detrás del bg opaco de .mvwin,
     solo el blur que escapa hacia fuera es visible: halo difuso puro. */

  .mvwin__aiglow {
    position: absolute;
    /* Círculo centrado, ~95% del lado más corto de .mvwin */
    top: 50%;
    left: 50%;
    height: 95%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: conic-gradient(
      from 0deg,
      #003399 0%,
      #00FFFF 16.66%,
      #1A66FF 33.33%,
      #4D99E6 50%,
      #002680 66.66%,
      #00FFFF 83.33%,
      #003399 100%
    );
    filter: blur(70px);
    opacity: 0;
    transform: translate(-50%, -50%);
    transition: opacity 0.7s ease-in-out;
    pointer-events: none;
    /* Forzar capa GPU dedicada — la rotación va por compositor */
    will-change: transform, opacity;
    animation: aiGlowRotate 5s linear infinite;
    animation-play-state: paused;
  }

  .mvwin-wrap.is-thinking .mvwin__aiglow {
    opacity: 1;
    animation-play-state: running;
  }

  /* Importante: incluir el translate(-50%,-50%) en cada keyframe
     para que la rotación no pierda el centrado */
  @keyframes aiGlowRotate {
    from { transform: translate(-50%, -50%) rotate(0deg); }
    to   { transform: translate(-50%, -50%) rotate(360deg); }
  }

  /* ── Ventana en sí ────────────────────────────────────────── */
  .mvwin {
    position: relative;
    border-radius: 28px;
    background: linear-gradient(180deg, #0A0A0C 0%, #060608 100%);
    border: 1px solid rgba(255, 255, 255, 0.06);
    box-shadow:
      0 60px 140px rgba(0, 0, 0, 0.7),
      0 30px 70px rgba(10, 132, 255, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
    padding: 28px 24px 24px;
  }

  /* Header */
  .mvwin__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 18px;
  }
  .mvwin__head h3 {
    margin: 0;
    font-size: 26px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
  }
  .mvwin__pill {
    padding: 6px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    color: var(--text);
    font-size: 13.5px;
    font-weight: 500;
  }

  /* Month total bar */
  .mvwin__month {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 0 4px 14px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    margin-bottom: 10px;
  }
  .mvwin__month-name {
    font-size: 17px;
    font-weight: 600;
    color: var(--text-muted);
  }
  .mvwin__month-total {
    font-size: 15px;
    color: var(--text-subtle);
    font-variant-numeric: tabular-nums;
  }

  /* List */
  .mvlist {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .mvr {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px 4px;
    position: relative;
  }
  .mvr + .mvr::before {
    content: '';
    position: absolute;
    top: 0;
    left: 62px;
    right: 4px;
    height: 1px;
    background: rgba(255, 255, 255, 0.05);
  }

  /* Icono cuadrado a la izquierda */
  .mvr__icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 11px;
    background: #2C2C2E;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 500ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .mvr__icon-spinner {
    position: absolute;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.15);
    border-top-color: rgba(255, 255, 255, 0.55);
    animation: mvSpin 1s linear infinite;
    transition: opacity 280ms ease-out;
  }
  .mvr__icon-svg {
    width: 22px;
    height: 22px;
    opacity: 0;
    transform: scale(0.6);
    transition:
      opacity 380ms ease-out,
      transform 380ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .mvr.is-categorized .mvr__icon { background: var(--mvr-color); }
  .mvr.is-categorized .mvr__icon-spinner { opacity: 0; }
  .mvr.is-categorized .mvr__icon-svg {
    opacity: 1;
    transform: scale(1);
  }
  @keyframes mvSpin {
    to { transform: rotate(360deg); }
  }

  /* Body: nombre + descriptor + tags */
  .mvr__body {
    flex: 1;
    min-width: 0;
  }
  .mvr__name {
    margin: 0;
    font-size: 16px;
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.01em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .mvr__sub {
    margin: 4px 0 0;
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .mvr__merch {
    font-size: 11.5px;
    font-weight: 500;
    letter-spacing: 0.045em;
    text-transform: uppercase;
    color: var(--text-subtle);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }
  .mvr__tag {
    flex-shrink: 0;
    padding: 1.5px 7px;
    border-radius: 5px;                      /* squircle, no pill */
    background: rgba(255, 255, 255, 0.07);
    color: rgba(255, 255, 255, 0.72);
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.005em;
    line-height: 1.45;
    /* aparece junto al icono coloreado */
    opacity: 0;
    transition: opacity 380ms ease-out 100ms;
  }
  .mvr.is-categorized .mvr__tag { opacity: 1; }

  /* Right side: date + amount */
  .mvr__date {
    margin: 0;
    flex-shrink: 0;
    font-size: 13px;
    color: var(--text-subtle);
    font-variant-numeric: tabular-nums;
    min-width: 88px;
    text-align: right;
  }
  .mvr__amount {
    margin: 0;
    flex-shrink: 0;
    font-size: 16px;
    font-weight: 600;
    color: var(--text-subtle);
    font-variant-numeric: tabular-nums;
    min-width: 92px;
    text-align: right;
    transition: color 380ms ease-out;
  }
  .mvr.is-categorized .mvr__amount { color: var(--red); }
  .mvr.is-categorized .mvr__amount.mvr__amount--in { color: var(--green); }

  /* ── Reduced motion ───────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .mvr__icon-spinner { animation: none; }
    .mvtos__col--text .section-title em { animation: none; }
    .mvwin-wrap.is-thinking .mvwin__aiglow { animation: none; }
  }

  /* ── Responsive ───────────────────────────────────────────── */
  @media (max-width: 1100px) {
    .mvr__date { min-width: 76px; font-size: 12.5px; }
    .mvr__amount { min-width: 84px; font-size: 15px; }
  }
  @media (max-width: 980px) {
    .mvtos__inner { grid-template-columns: 1fr; gap: 56px; }
    .mvtos__col--text {
      max-width: 100%;
      text-align: center;
    }
    .mvtos__col--text .section-lead { margin: 0 auto; }
    .mvwin { padding: 22px 18px 18px; }
    .mvwin__head h3 { font-size: 22px; }
    /* En el momento en que el grid pasa a 1 columna las filas quedan
       muy apretadas con la fecha — la quitamos para dejar respirar al
       merchant + tags + importe. La info de fecha sigue accesible al
       abrir el detalle del movimiento en la app real. */
    .mvr__date { display: none; }
  }
  @media (max-width: 640px) {
    .mvr { gap: 10px; padding: 10px 2px; }
    .mvr + .mvr::before { left: 56px; right: 2px; }
    .mvr__icon { width: 40px; height: 40px; border-radius: 10px; }
    .mvr__icon-svg { width: 20px; height: 20px; }
    .mvr__name { font-size: 15px; }
    .mvr__sub { gap: 6px; }
    .mvr__merch { font-size: 10.5px; }
    .mvr__tag { font-size: 10px; padding: 2px 7px; }
    .mvr__amount { font-size: 15px; min-width: 78px; }
  }
</style>
