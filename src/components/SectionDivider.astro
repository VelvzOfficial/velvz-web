---
/**
 * Conector sutil entre secciones.
 *
 * Crea una "costura" de ~140 px de alto centrada en la frontera entre dos
 * secciones, compuesta por:
 *   - Un halo radial azul muy difuso (80 px de blur) — atmósfera
 *   - Una hairline horizontal de 1 px con gradient (transparente → azul leve
 *     → transparente) — el seam visible
 * Sin pulsación ni movimiento — es decoración estática.
 */
---

<div class="divider" aria-hidden="true">
  <div class="divider__glow"></div>
  <div class="divider__line"></div>
</div>

<style>
  .divider {
    position: relative;
    width: 100%;
    height: 1px; /* el contenedor no ocupa espacio real */
    pointer-events: none;
    z-index: 1;
  }

  /* Halo azul difuso centrado en la costura */
  .divider__glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 80%;
    max-width: 900px;
    height: 220px;
    background: radial-gradient(
      ellipse at center,
      rgba(26, 102, 255, 0.18) 0%,
      rgba(26, 102, 255, 0.06) 35%,
      transparent 70%
    );
    filter: blur(50px);
  }

  /* Hairline en el centro — fade en los bordes para que no se corte feo */
  .divider__line {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 64%;
    max-width: 720px;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent 0%,
      rgba(255, 255, 255, 0.04) 25%,
      rgba(77, 153, 230, 0.25) 50%,
      rgba(255, 255, 255, 0.04) 75%,
      transparent 100%
    );
  }
</style>
