---

<section class="cop" id="copiloto" data-cop>
  <!-- Composición central va fuera del cloud para que se quede estática -->
  <div class="cop__cloud">
    <!-- Capa 2: cards atmosféricas borrosas (van detrás) -->
    {bgCards.map((c) => {
      const inline = `top:${c.y};left:${c.x};--rot:${c.r};--blur:${c.blur}px;--dur:${c.dur};--delay:${c.delay};width:${c.width}px;--target-opacity:${c.opacity};`;
      return (
        <div class="cop-atom" data-blur={c.blur} style={inline} aria-hidden="true">{c.text}</div>
      );
    })}

    <!-- Capa 1: insight cards legibles -->
    {cards.map((c) => {
      const inline = `top:${c.y};left:${c.x};--rot:${c.r};--blur:${c.blur}px;--dur:${c.dur};--delay:${c.delay};`;
      return (
        <article class={`cop-card cop-card--${c.size}`} data-blur={c.blur} style={inline} aria-hidden="true">
          <p class="cop-card__label">{c.label}</p>
          <p class="cop-card__value">{c.value}</p>
          {c.sub && <p class="cop-card__sub">{c.sub}</p>}
        </article>
      );
    })}
  </div>

  <!-- Composición central: cara + título + subtítulo (estática, no rota) -->
  <div class="cop__center">
    <div class="cop__face" aria-hidden="true">
      <VelvzFace size={140} color="#FFFFFF" />
    </div>
    <h2 class="section-title">
      Siempre <em>atentos</em>.
    </h2>
    <p class="section-lead">
      Velvz analiza continuamente tus finanzas para detectar patrones
      interesantes o avisarte de anomalías.
    </p>
  </div>
</section>

<script is:inline>
  /**
   * Aparición staggered de los widgets cuando el copiloto entra en viewport.
   * Orden: por profundidad (menos blur = más adelante = primero).
   */
  (() => {
    const section = document.querySelector('[data-cop]');
    if (!section) return;

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) return; // CSS los muestra ya visibles

    const center = section.querySelector('.cop__center');
    const all = section.querySelectorAll('.cop-card, .cop-atom');

    // Ordena de menos blur a más blur — los más nítidos (foreground) primero
    const sorted = Array.from(all).sort((a, b) => {
      return parseFloat(a.dataset.blur || '0') - parseFloat(b.dataset.blur || '0');
    });

    let triggered = false;
    const reveal = () => {
      if (triggered) return;
      triggered = true;

      // Widget central aparece primero
      if (center) center.classList.add('is-entered');

      // Cards staggered por depth — 70 ms entre cada una (más lento que antes)
      const stagger = 70;
      sorted.forEach((el, i) => {
        setTimeout(() => el.classList.add('is-entered'), (i + 1) * stagger);
      });
    };

    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            io.disconnect();
            reveal();
            return;
          }
        }
      },
      { threshold: 0.2 }
    );
    io.observe(section);
  })();

  /* Aplica la animación de parpadeo INLINE en cada ojo. El estilo inline
     gana siempre la cascada (más alto que cualquier rule, !important o no),
     así que la regla del script global de VelvzFace ya no nos pisa.
     Esperamos un tick para que VelvzFace haya pintado los <span> hijos. */
  (() => {
    const apply = () => {
      const eyes = document.querySelectorAll('.cop__face .velvz-face__eye');
      eyes.forEach((eye) => {
        eye.style.animation = 'copFaceBlinkLoop 5s ease-in-out infinite';
      });
    };
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', apply, { once: true });
    } else {
      // Defer un frame para asegurar que VelvzFace ya está en el DOM
      requestAnimationFrame(apply);
    }
  })();
</script>

<style>
  .cop {
    position: relative;
    overflow: hidden;
    padding: var(--section-py) 0;
  }

  /* ── Cloud ───────────────────────────────────────────────── */
  .cop__cloud {
    position: relative;
    width: 100%;
    max-width: 1280px;
    height: 800px;
    margin: 0 auto;
  }

  /* ── Composición central como widget grande ───────────────── */
  .cop__center {
    position: absolute;
    top: 50%;
    left: 50%;
    /* Uso `translate` (propiedad CSS moderna) en vez de `transform: translate()`
       para que la animación de float pueda operar sobre translate sin pisar
       el transform que usan otras cosas. */
    translate: -50% -50%;
    z-index: 20;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: 640px;
    max-width: calc(100% - 48px);
    gap: 24px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.03));
    border: 1px solid rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(24px) saturate(160%);
    -webkit-backdrop-filter: blur(24px) saturate(160%);
    border-radius: 28px;
    padding: 56px 56px;
    box-shadow: 0 50px 120px rgba(0, 0, 0, 0.7);
    opacity: 0;
    transition: opacity 1.1s ease-out;
    /* Float ligero del widget entero (cara + texto se mueven juntos) */
    animation: copCenterFloat 8s ease-in-out infinite alternate;
  }
  .cop__center.is-entered { opacity: 1; }
  @keyframes copCenterFloat {
    from { translate: -50% -50%; }
    to   { translate: -50% calc(-50% - 8px); }
  }

  /* (El parpadeo se aplica vía JS inline más abajo — la animación CSS
     se quedaba bloqueada por la cascada del componente VelvzFace, así
     que aplicamos `animation` por inline-style desde JS, que gana siempre.) */

  /* Override del em para usar el gradiente azul glow IA */
  .cop__center .section-title {
    margin: 0;
  }
  .cop__center .section-title em {
    font-style: normal;
    background: linear-gradient(120deg, #4D99E6 0%, #1A66FF 50%, #003399 100%);
    background-size: 200% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: copGradSlide 8s ease-in-out infinite;
  }
  @keyframes copGradSlide {
    0%, 100% { background-position: 0% 50%; }
    50%      { background-position: 100% 50%; }
  }
  .cop__center .section-lead {
    margin: 0;
  }

  /* ── Capa 2: cards atmosféricas (background, blureadas) ──── */
  /* Uso translate + rotate como propiedades separadas (no transform
     shorthand) para que el animation de float (translate) y el de
     counter-rotate (rotate) puedan correr juntos sin pisarse. */
  .cop-atom {
    position: absolute;
    translate: -50% -50%;
    rotate: var(--rot, 0deg);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.025));
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 9px 14px;
    color: var(--text-muted);
    font-size: 13px;
    font-weight: 500;
    text-align: center;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    box-sizing: border-box;
    z-index: 1;
    /* opacidad target por card (variación de profundidad) — el JS la activa
       al hacer scroll (animación de aparición) */
    opacity: 0;
    filter: blur(var(--blur, 5px));
    transition: opacity 1s ease-out;
    animation: copFloat var(--dur, 8s) ease-in-out var(--delay, 0s) infinite alternate;
  }
  .cop-atom.is-entered { opacity: var(--target-opacity, 0.5); }

  /* ── Capa 1: insight cards legibles (foreground) ─────────── */
  .cop-card {
    position: absolute;
    translate: -50% -50%;
    rotate: var(--rot, 0deg);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.025));
    border: 1px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(20px) saturate(140%);
    -webkit-backdrop-filter: blur(20px) saturate(140%);
    border-radius: 18px;
    padding: 16px 20px;
    box-shadow: 0 24px 50px rgba(0, 0, 0, 0.5);
    color: var(--text);
    z-index: 5;
    opacity: 0;
    filter: blur(var(--blur, 0px));
    transition: opacity 1s ease-out;
    animation: copFloat var(--dur, 6s) ease-in-out var(--delay, 0s) infinite alternate;
  }
  .cop-card.is-entered { opacity: 1; }

  .cop-card--lg { width: 280px; }
  .cop-card--md { width: 220px; }
  .cop-card--sm { width: 160px; }

  .cop-card__label {
    margin: 0 0 6px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-subtle);
  }
  .cop-card__value {
    margin: 0;
    font-size: 26px;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: var(--text);
  }
  .cop-card--md .cop-card__value { font-size: 22px; }
  .cop-card--sm .cop-card__value { font-size: 19px; }
  .cop-card__sub {
    margin: 6px 0 0;
    font-size: 12.5px;
    color: var(--text-muted);
    line-height: 1.35;
  }

  /* Float vertical: solo anima translate (rotate se queda fijo) */
  @keyframes copFloat {
    from { translate: -50% -50%; }
    to   { translate: -50% calc(-50% - 12px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .cop-card, .cop-atom, .cop__face { animation: none; }
    .cop__center .section-title em { animation: none; }
    /* Sin reduced motion estás esperando JS para opacity. Forzamos visible. */
    .cop-card { opacity: 1; transition: none; }
    .cop-atom { opacity: var(--target-opacity, 0.5); transition: none; }
    .cop__center { opacity: 1; transition: none; }
  }
</style>

<!-- Keyframes en estilo global para que esté accesible desde la animación
     inline que aplica el script de abajo. -->
<style is:global>
  @keyframes copFaceBlinkLoop {
    0%, 38%, 41%, 76%, 79%, 100% { transform: scaleY(1); }
    39.5%, 77.5%                 { transform: scaleY(0.1); }
  }

  /* ── Responsive ───────────────────────────────────────────── */
  @media (max-width: 980px) {
    .cop__cloud { height: 700px; }
    .cop-card--lg { width: 240px; }
    .cop-card--md { width: 190px; }
    .cop-card--sm { width: 140px; }
    .cop-card__value { font-size: 22px; }
    .cop__center { width: 480px; }
  }
  @media (max-width: 640px) {
    .cop__cloud { height: 620px; }
    .cop-card--lg { width: 200px; padding: 14px 16px; }
    .cop-card--md { width: 170px; padding: 12px 14px; }
    .cop-card--sm { width: 130px; padding: 10px 12px; }
    .cop-card__value { font-size: 18px; }
    /* Ocultar la mitad de las atmosféricas en móvil para no saturar */
    .cop-atom:nth-child(odd) { display: none; }
  }
</style>
