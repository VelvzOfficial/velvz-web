---
import VelvzFace from './VelvzFace.astro';
---

<section class="hero" id="top">
  <!-- Aurora -->
  <div class="hero__aurora" aria-hidden="true">
    <img src="/hero-bg.png" alt="" />
  </div>
  <div class="hero__glow hero__glow--blue" aria-hidden="true"></div>
  <div class="hero__glow hero__glow--violet" aria-hidden="true"></div>
  <div class="grain" aria-hidden="true"></div>

  <div class="hero__inner container">
    <!-- Carita protagonista -->
    <div class="hero__face reveal" style="--reveal-delay: .05s">
      <div class="hero__face-halo" aria-hidden="true"></div>
      <VelvzFace size={170} color="#FFFFFF" />
    </div>

    <span class="hero__pill reveal" style="--reveal-delay: .15s">
      <span class="hero__pill-dot"></span>
      Próximamente en App Store
    </span>

    <h1 class="hero__title">
      <span class="hero__title-line reveal" style="--reveal-delay: .25s">Tu copiloto</span>
      <span class="hero__title-line reveal" style="--reveal-delay: .35s">
        financiero, hecho<br /> para <em>Apple</em>.
      </span>
    </h1>

    <p class="hero__subtitle reveal" style="--reveal-delay: .55s">
      Conecta tu banco, deja que la IA lo ordene y háblale como a un contable
      de confianza. iPhone, iPad y Mac, desde el primer día.
    </p>

    <div class="hero__cta-wrap reveal" style="--reveal-delay: .7s">
      <a href="#waitlist" class="hero__cta">
        <span class="hero__cta-bg" aria-hidden="true"></span>
        <span class="hero__cta-text">Solicitar acceso a la beta</span>
        <svg class="hero__cta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M13 5l7 7-7 7" />
        </svg>
      </a>
      <p class="hero__cta-hint">Sin spam. Te avisamos cuando se abra.</p>
    </div>

    <!-- Mac aterrizando -->
    <div class="hero__mac reveal" style="--reveal-delay: .9s" aria-hidden="true">
      <div class="hero__mac-glow"></div>
      <img src="/mockups/panel-mac.png" alt="Velvz en Mac mostrando el panel principal" />
    </div>
  </div>

  <div class="hero__scroll" aria-hidden="true">
    <span class="hero__scroll-line"></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding: 140px 0 0;
    text-align: center;
  }

  .hero__inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Aurora */
  .hero__aurora {
    position: absolute;
    inset: -10% -5% 0;
    z-index: -3;
    pointer-events: none;
  }
  .hero__aurora img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    opacity: 0.75;
    transform: scale(1.15) rotate(180deg);
    filter: blur(2px) saturate(120%);
  }
  .hero__aurora::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 50% 0%, transparent 0%, rgba(5, 5, 7, 0.5) 60%, var(--bg) 95%),
      linear-gradient(to bottom, transparent 0%, var(--bg) 92%);
  }

  .hero__glow {
    position: absolute;
    z-index: -2;
    pointer-events: none;
    border-radius: 50%;
    filter: blur(90px);
    opacity: 0.6;
    animation: heroBreathe 8s ease-in-out infinite;
  }
  .hero__glow--blue {
    width: 760px;
    height: 760px;
    top: -140px;
    left: 50%;
    transform: translateX(-50%);
    background: radial-gradient(circle, var(--accent) 0%, transparent 65%);
  }
  .hero__glow--violet {
    width: 540px;
    height: 540px;
    top: 80px;
    left: 50%;
    transform: translateX(-30%);
    background: radial-gradient(circle, var(--violet) 0%, transparent 70%);
    opacity: 0.32;
    animation: heroBreatheViolet 10s ease-in-out infinite;
    animation-delay: -3s;
  }
  @keyframes heroBreathe {
    0%, 100% { transform: translateX(-50%) scale(1); opacity: 0.6; }
    50%      { transform: translateX(-50%) scale(1.08); opacity: 0.75; }
  }
  @keyframes heroBreatheViolet {
    0%, 100% { transform: translateX(-30%) scale(1); opacity: 0.32; }
    50%      { transform: translateX(-30%) scale(1.1); opacity: 0.5; }
  }

  /* Carita */
  .hero__face {
    position: relative;
    margin-bottom: 30px;
  }
  .hero__face-halo {
    position: absolute;
    inset: -120px;
    background: radial-gradient(
      circle at 50% 50%,
      rgba(10, 132, 255, 0.5) 0%,
      rgba(10, 132, 255, 0.18) 30%,
      transparent 60%
    );
    filter: blur(40px);
    pointer-events: none;
    animation: heroBreathe 6s ease-in-out infinite;
  }

  /* Pill */
  .hero__pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 14px 7px 12px;
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--text);
    margin-bottom: 30px;
  }
  .hero__pill-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 12px var(--accent-glow);
    animation: pillPulse 2.4s ease-in-out infinite;
  }
  @keyframes pillPulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.5; transform: scale(0.85); }
  }

  /* Title */
  .hero__title {
    margin: 0 0 24px;
    font-size: clamp(48px, 8.4vw, 116px);
    font-weight: 700;
    line-height: 0.96;
    letter-spacing: -0.035em;
    color: var(--text);
    max-width: 16ch;
  }
  .hero__title-line {
    display: block;
  }
  .hero__title em {
    font-style: normal;
    background: linear-gradient(120deg, #4DA3FF 0%, #0A84FF 40%, #6E5BFF 100%);
    background-size: 200% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: gradientSlide 8s ease-in-out infinite;
  }
  @keyframes gradientSlide {
    0%, 100% { background-position: 0% 50%; }
    50%      { background-position: 100% 50%; }
  }

  /* Subtitle */
  .hero__subtitle {
    margin: 0 auto 36px;
    font-size: clamp(15px, 1.3vw, 19px);
    line-height: 1.55;
    color: var(--text-muted);
    max-width: 540px;
  }

  /* CTA */
  .hero__cta-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    margin-bottom: 100px;
  }
  .hero__cta {
    position: relative;
    isolation: isolate;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 16px 28px;
    border-radius: var(--radius-pill);
    color: #fff;
    font-size: 16px;
    font-weight: 600;
    letter-spacing: -0.005em;
    overflow: hidden;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    box-shadow:
      0 12px 40px rgba(10, 132, 255, 0.45),
      inset 0 1px 0 rgba(255, 255, 255, 0.25);
  }
  .hero__cta-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, #0A84FF 0%, #2E6BFF 50%, #6E5BFF 100%);
    background-size: 200% 100%;
    z-index: -1;
    animation: gradientSlide 6s ease-in-out infinite;
  }
  .hero__cta-icon { width: 18px; height: 18px; transition: transform 0.25s ease; }
  .hero__cta:hover {
    transform: translateY(-2px);
    box-shadow:
      0 20px 60px rgba(10, 132, 255, 0.6),
      inset 0 1px 0 rgba(255, 255, 255, 0.3);
  }
  .hero__cta:hover .hero__cta-icon { transform: translateX(4px); }
  .hero__cta-hint { margin: 0; font-size: 12.5px; color: var(--text-subtle); }

  /* Mac aterrizando */
  .hero__mac {
    position: relative;
    width: 100%;
    max-width: 1080px;
    margin: 0 auto;
    padding-bottom: 80px;
  }
  .hero__mac img {
    width: 100%;
    height: auto;
    filter:
      drop-shadow(0 60px 120px rgba(10, 132, 255, 0.35))
      drop-shadow(0 30px 80px rgba(0, 0, 0, 0.7));
    animation: macFloat 10s ease-in-out infinite;
  }
  .hero__mac-glow {
    position: absolute;
    left: 50%;
    bottom: 0;
    width: 80%;
    height: 240px;
    transform: translateX(-50%);
    background: radial-gradient(ellipse at center, rgba(10, 132, 255, 0.45) 0%, transparent 65%);
    filter: blur(60px);
    pointer-events: none;
    z-index: -1;
  }
  @keyframes macFloat {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-12px); }
  }

  /* Scroll indicator */
  .hero__scroll {
    position: absolute;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    width: 1px;
    height: 60px;
    overflow: hidden;
    z-index: 5;
    opacity: 0.4;
  }
  .hero__scroll-line {
    display: block;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, transparent, var(--text), transparent);
    animation: scrollLine 2.4s ease-in-out infinite;
  }
  @keyframes scrollLine {
    0%   { transform: translateY(-100%); }
    100% { transform: translateY(100%); }
  }

  @media (max-width: 820px) {
    .hero { padding: 110px 0 0; }
    .hero__face :global(.velvz-face) { --face-size: 130px !important; }
    .hero__title { letter-spacing: -0.03em; }
  }
  @media (max-width: 540px) {
    .hero { padding: 90px 0 0; }
    .hero__face :global(.velvz-face) { --face-size: 100px !important; }
    .hero__title { font-size: clamp(38px, 11vw, 60px); }
    .hero__cta { padding: 14px 22px; font-size: 15px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__glow, .hero__face-halo, .hero__mac img { animation: none !important; }
  }
</style>
