---
/**
 * Sección 4 — Libros
 * Concepto diferencial. Sidebar de libros real (replicada con CSS) + captura
 * del libro Supermercado al lado. La idea: la IA reparte el dinero en
 * libros que tú defines, no en categorías genéricas.
 */

const libros = [
  { name: 'Todos los libros', icon: 'books', tint: 'red' },
  { name: 'Gasolina', icon: 'fuel', tint: 'blue' },
  { name: 'Supermercado', icon: 'cart', tint: 'green', active: true },
  { name: 'Restaurantes', icon: 'fork', tint: 'orange' },
  { name: 'Trabajo', icon: 'briefcase', tint: 'red' },
  { name: 'Inversiones', icon: 'chart', tint: 'green' },
];
---

<section class="libros" id="libros">
  <div class="libros__bg" aria-hidden="true">
    <div class="libros__halo"></div>
  </div>

  <div class="container container--wide libros__inner">
    <div class="libros__col libros__col--shot reveal">
      <div class="libros-shot">
        <div class="libros-shot__glow"></div>
        <img src="/screens/libro-mac.png" alt="Libro Supermercado en Velvz: total gastado, gasto medio, evolución y comparativas anuales." loading="lazy" />
      </div>

      <!-- Sidebar flotante de libros -->
      <aside class="libros-side reveal" style="--reveal-delay: .25s" aria-hidden="true">
        <p class="libros-side__title">Libros</p>
        <ul>
          {libros.map((l) => (
            <li class={`libros-side__item ${l.active ? 'is-active' : ''} libros-side__item--${l.tint}`}>
              <span class="libros-side__icon">
                {l.icon === 'books' && (
                  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M4 5h4v14H4zM10 5h4v14h-4zM16 5l4 1-2 13-4-1z"/></svg>
                )}
                {l.icon === 'fuel' && (
                  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M5 3h8v8H5zM5 11h8v9H5zM14 8l3 1v9a2 2 0 1 1-4 0V8z"/></svg>
                )}
                {l.icon === 'cart' && (
                  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3 4h2l2 12h12l2-8H7"/><circle cx="9" cy="20" r="1.6"/><circle cx="17" cy="20" r="1.6"/></svg>
                )}
                {l.icon === 'fork' && (
                  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M7 3v8a2 2 0 1 0 4 0V3M9 11v10M16 3l-1 6 2 1v11"/></svg>
                )}
                {l.icon === 'briefcase' && (
                  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M9 5h6v3h5v12H4V8h5z"/></svg>
                )}
                {l.icon === 'chart' && (
                  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M4 19h16v2H4zM4 17V8h3v9zM10 17V4h3v13zM16 17v-7h3v7z"/></svg>
                )}
              </span>
              <span class="libros-side__name">{l.name}</span>
            </li>
          ))}
        </ul>
      </aside>
    </div>

    <div class="libros__col libros__col--text">
      <span class="eyebrow reveal">Los libros</span>
      <h2 class="section-title reveal" style="--reveal-delay: .1s">
        Libros, no <em>categorías</em>.
      </h2>
      <p class="section-lead reveal" style="--reveal-delay: .2s">
        Define el dinero a tu manera: Gasolina, Supermercado, Trabajo, esa
        boda en julio. La IA reparte cada movimiento donde toca y construye
        métricas, gráficas y predicciones para cada libro.
      </p>

      <ul class="libros__bullets">
        <li class="reveal" style="--reveal-delay: .3s">
          <span class="libros__bullet-tag">01</span>
          <div>
            <p class="libros__bullet-t">Tú decides los libros</p>
            <p class="libros__bullet-s">Crea, renombra y archiva con un toque.</p>
          </div>
        </li>
        <li class="reveal" style="--reveal-delay: .4s">
          <span class="libros__bullet-tag">02</span>
          <div>
            <p class="libros__bullet-t">La IA hace el reparto</p>
            <p class="libros__bullet-s">Aprende de tus correcciones y las recuerda.</p>
          </div>
        </li>
        <li class="reveal" style="--reveal-delay: .5s">
          <span class="libros__bullet-tag">03</span>
          <div>
            <p class="libros__bullet-t">Cada libro, su propia historia</p>
            <p class="libros__bullet-s">Evolución mensual, anual y comparativas.</p>
          </div>
        </li>
      </ul>
    </div>
  </div>
</section>

<style>
  .libros {
    position: relative;
    isolation: isolate;
    padding: var(--section-py) 0;
    overflow: hidden;
  }
  .libros__bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
  }
  .libros__halo {
    position: absolute;
    top: 20%;
    left: -10%;
    width: 800px;
    height: 800px;
    background: radial-gradient(circle, var(--green) 0%, transparent 65%);
    opacity: 0.08;
    filter: blur(140px);
  }

  .libros__inner {
    display: grid;
    grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
    gap: 80px;
    align-items: center;
  }

  .libros__col--shot {
    position: relative;
  }
  .libros-shot {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow:
      0 50px 120px rgba(0, 0, 0, 0.6),
      0 30px 60px rgba(52, 209, 88, 0.18);
    transform: perspective(1800px) rotateY(3deg) rotateX(2deg);
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .libros-shot:hover { transform: perspective(1800px) rotateY(0) rotateX(0); }
  .libros-shot img { width: 100%; height: auto; display: block; }
  .libros-shot__glow {
    position: absolute;
    inset: -1px;
    border-radius: var(--radius-lg);
    background: linear-gradient(135deg, rgba(52,209,88,0.35), rgba(10,132,255,0.25));
    z-index: -1;
    filter: blur(40px);
    opacity: 0.5;
  }

  /* Sidebar flotante */
  .libros-side {
    position: absolute;
    top: -8%;
    left: -2%;
    width: 220px;
    padding: 16px 12px;
    border-radius: var(--radius);
    background: linear-gradient(180deg, rgba(20,20,24,0.95), rgba(14,14,16,0.92));
    border: 1px solid var(--border-strong);
    backdrop-filter: blur(20px) saturate(160%);
    -webkit-backdrop-filter: blur(20px) saturate(160%);
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.6);
    animation: sideFloat 9s ease-in-out infinite;
  }
  .libros-side__title {
    margin: 0 8px 8px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-subtle);
  }
  .libros-side ul { list-style: none; margin: 0; padding: 0; }
  .libros-side__item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 10px;
    border-radius: var(--radius-sm);
    font-size: 13.5px;
    color: var(--text);
    transition: background 0.2s ease;
  }
  .libros-side__item.is-active {
    background: rgba(10, 132, 255, 0.18);
  }
  .libros-side__icon {
    width: 22px;
    height: 22px;
    border-radius: 6px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .libros-side__icon svg { width: 14px; height: 14px; }
  .libros-side__item--red .libros-side__icon { background: rgba(255, 105, 97, 0.18); color: var(--red); }
  .libros-side__item--blue .libros-side__icon { background: var(--accent-soft); color: var(--accent-2); }
  .libros-side__item--green .libros-side__icon { background: rgba(52, 209, 88, 0.18); color: var(--green); }
  .libros-side__item--orange .libros-side__icon { background: rgba(255, 159, 10, 0.18); color: var(--orange); }

  @keyframes sideFloat {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-10px); }
  }

  /* Bullets */
  .libros__col--text { max-width: 520px; }
  .libros__bullets {
    list-style: none;
    padding: 0;
    margin: 36px 0 0;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .libros__bullets li {
    display: flex;
    gap: 18px;
    align-items: flex-start;
  }
  .libros__bullet-tag {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent-2);
    letter-spacing: 0.08em;
    padding-top: 4px;
  }
  .libros__bullet-t { margin: 0 0 4px; font-size: 17px; font-weight: 600; }
  .libros__bullet-s { margin: 0; font-size: 14.5px; color: var(--text-muted); }

  @media (max-width: 980px) {
    .libros__inner { grid-template-columns: 1fr; gap: 56px; }
    .libros__col--shot { order: 2; }
    .libros__col--text { order: 1; max-width: 100%; }
    .libros-shot { transform: none; }
    .libros-side { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .libros-side { animation: none; }
  }
</style>
