---
import Layout from '../layouts/Layout.astro';

const faqs = [
  {
    q: '¿Es seguro conectar mi banco?',
    a: 'Sí. Utilizamos Open Banking (PSD2), el estándar europeo regulado. Solo accedemos a tus datos en modo lectura a través de Enable Banking, un proveedor autorizado. Nunca tenemos acceso a tus credenciales bancarias ni podemos realizar operaciones en tu cuenta.',
  },
  {
    q: '¿Dónde se guardan mis datos?',
    a: 'En tu iCloud privado (Apple CloudKit). Nosotros no almacenamos datos financieros en nuestros servidores. Tus datos son tuyos y están cifrados por Apple.',
  },
  {
    q: '¿Cómo desconecto mi banco?',
    a: 'Desde la sección de cuentas bancarias en la app, pulsa "Desconectar". La autorización se revoca inmediatamente.',
  },
  {
    q: '¿Puedo eliminar mis datos?',
    a: 'Sí. En la app, ve a Ajustes → Privacidad e IA → Eliminar todos mis datos. La acción borra inmediatamente movimientos, suscripciones, libros, widgets y categorías personalizadas. Es irreversible. Si prefieres una eliminación completa también del lado servidor, escríbenos a contact@velvz.com y la procesamos manualmente.',
  },
  {
    q: '¿Cómo descargo todos mis datos?',
    a: 'Ve a Ajustes → Privacidad e IA → Exportar mis datos. La app genera un archivo JSON con tu perfil, movimientos, suscripciones, libros, widgets, categorías y referencias a tus archivos. Puedes guardarlo donde quieras desde el panel de exportación.',
  },
];

// Schema FAQPage para que Google muestre las preguntas en los resultados
// (rich result de FAQ debajo del enlace de la página).
const faqSchema = {
  '@type': 'FAQPage',
  '@id': 'https://velvz.com/support/#faq',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Layout
  title="Soporte y FAQ — Velvz"
  description="Soporte de Velvz: contacto (contact@velvz.com) y preguntas frecuentes sobre seguridad bancaria PSD2, almacenamiento de datos en iCloud, eliminación y exportación de datos."
  extraSchema={faqSchema}
>
  <main class="legal">
    <a href="/" class="legal__back">&larr; Velvz</a>
    <h1>Soporte</h1>

    <h2>Contacto</h2>
    <p>Si tienes problemas con la app, preguntas o sugerencias, contacta con nosotros:</p>

    <div class="legal__card">
      <p><strong>Email</strong></p>
      <p><a href="mailto:contact@velvz.com">contact@velvz.com</a></p>
      <p style="margin-top:14px"><strong>Tiempo de respuesta</strong></p>
      <p>Intentamos responder en 24-48 horas laborables.</p>
    </div>

    <h2>Preguntas frecuentes</h2>

    {faqs.map((f) => (
      <Fragment>
        <h3>{f.q}</h3>
        <p>{f.a}</p>
      </Fragment>
    ))}
  </main>
</Layout>

<!-- Estilos `.legal*` (incluido `.legal__card`) viven en global.css. -->
